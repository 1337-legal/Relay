# Copy to `.env` for local development (loaded automatically in debug builds).

# Postgres connection string.
DATABASE_URL=postgres://user:pass@localhost/relay

# DKIM signing.
DKIM_DOMAIN=1337.legal
DKIM_SELECTOR=default
DKIM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional: enable STARTTLS. These hold the PEM *contents* (not file paths).
# Use a double-quoted multi-line value, or a single line with `\n` escapes.
# RELAY_CERTIFICATES="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# RELAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional: override the listen address (default 0.0.0.0:25).
RELAY_BIND=127.0.0.1:2525

# Optional: log filter.
RUST_LOG=info
